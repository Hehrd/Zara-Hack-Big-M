# Leave empty for same-origin requests. Point this at Spring Boot when ready.
VITE_API_BASE_URL=
# MSW is enabled in development unless explicitly disabled.
VITE_ENABLE_MOCKS=true
# Browser-restricted Google Maps JavaScript API key.
VITE_GOOGLE_MAPS_API_KEY=
# Optional vector map ID used for tilted 3D mode.
VITE_GOOGLE_MAPS_MAP_ID=

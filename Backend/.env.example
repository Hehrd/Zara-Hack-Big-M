APP_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-bytes
APP_AUTH_ISSUER=zara-hack-preparation
APP_AUTH_ACCESS_TOKEN_TTL=PT15M
APP_AUTH_REFRESH_TOKEN_TTL=P30D

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/zara_hack
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_DATASOURCE_USERNAME=zara_user
SPRING_DATASOURCE_PASSWORD=replace-with-a-strong-db-password
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_H2_CONSOLE_ENABLED=false

POSTGRES_DB=zara_hack
POSTGRES_USER=zara_user
POSTGRES_PASSWORD=replace-with-a-strong-db-password

SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=replace-with-a-strong-redis-password
SPRING_DATA_REDIS_TIMEOUT=2s
SPRING_CACHE_REDIS_TIME_TO_LIVE=PT10M

SERVER_PORT=6969

# Auth
APP_AUTH_SECRET=replace-with-long-random-secret
APP_AUTH_ISSUER=zara-hack-preparation
APP_AUTH_ACCESS_TOKEN_TTL=PT15M
APP_AUTH_REFRESH_TOKEN_TTL=P30D

# Database (datasource placeholders read by application.yml)
SUPABASE_DB_URL=jdbc:postgresql://YOUR_POOLER_HOST:5432/postgres?sslmode=require
SUPABASE_DB_USER=postgres.your-project-ref
SUPABASE_DB_PASSWORD=your-supabase-database-password

SERVER_PORT=6969

# Location service integrations
APP_LOCATION_MODEL_SERVICE_URL=http://localhost:8000

# Browser-restricted Google Maps key (server sends APP_LOCATION_GOOGLE_MAPS_REFERER as Referer)
APP_LOCATION_GOOGLE_MAPS_KEY=your-google-maps-browser-key
APP_LOCATION_GOOGLE_MAPS_REFERER=https://your-frontend-origin

# OpenAI-compatible endpoint
APP_LOCATION_OPENAI_KEY=your-openai-api-key
APP_LOCATION_OPENAI_URL=https://proxy.openkbs.com/v1/openai/chat/completions
APP_LOCATION_OPENAI_MODEL=gpt-5.4-mini

# Optional Spark / runtime path overrides (defaults defined in application.yml)
# APP_LOCATION_SPARK_SUBMIT_PATH=
# APP_LOCATION_SPARK_JOB_PATH=
# APP_LOCATION_PRECOMPUTED_LAYERS_PATH=
# APP_LOCATION_JAVA_HOME=
# APP_LOCATION_SPARK_HOME=
# APP_LOCATION_PYTHON_PATH=
# APP_LOCATION_RUN_DIR=
# APP_LOCATION_RESULT_COUNT=3
